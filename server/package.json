{
  "name": "interviewready-ai-server",
  "version": "1.0.0",
  "description": "Backend API for InterviewReady AI",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon --watch server.js --watch evaluation.js --watch validation.js --watch ai --watch .env --ext js,mjs,cjs,json,env server.js",
