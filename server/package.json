    "express": "^5.1.0",
    "express-rate-limit": "8.5.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
